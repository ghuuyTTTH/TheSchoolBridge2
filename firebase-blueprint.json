{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "parent"] },
        "studentId": { "type": "string" },
        "schoolCode": { "type": "string" },
        "childStudentId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "name", "email", "role", "createdAt"]
    },
    "Class": {
      "title": "Class",
      "description": "Class group managed by a teacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "classCode": { "type": "string" },
        "className": { "type": "string" },
        "createdAt": { "type": "number" },
        "studentIds": { "type": "array", "items": { "type": "string" } },
        "pendingIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "teacherId", "classCode", "className", "createdAt", "studentIds", "pendingIds"]
    },
    "Message": {
      "title": "Message",
      "description": "Direct message between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" },
        "isRead": { "type": "boolean" }
      },
      "required": ["id", "senderId", "receiverId", "text", "timestamp", "isRead"]
    },
    "HelpRequest": {
      "title": "Help Request",
      "description": "A request for help from a student",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string" },
        "isAnonymous": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pending", "resolved"] }
      },
      "required": ["id", "studentId", "subject", "message", "timestamp", "isAnonymous", "status"]
    },
    "MoodLog": {
      "title": "Mood Log",
      "description": "Emotional check-in from a student",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "mood": { "type": "string", "enum": ["happy", "neutral", "sad", "stressed"] },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "userId", "mood", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notification for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "to": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "timestamp": { "type": "number" },
        "read": { "type": "boolean" }
      },
      "required": ["id", "to", "title", "message", "type", "timestamp", "read"]
    },
    "StudentProgress": {
      "title": "Student Progress",
      "description": "Academic and gamification progress for a student",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "badges": { "type": "array" },
        "points": { "type": "number" },
        "level": { "type": "number" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "classes/{classId}": {
      "schema": "Class",
      "description": "Classes"
    },
    "messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages"
    },
    "helpRequests/{requestId}": {
      "schema": "HelpRequest",
      "description": "Help requests"
    },
    "moodLogs/{logId}": {
      "schema": "MoodLog",
      "description": "Mood history"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "studentProgress/{userId}": {
      "schema": "StudentProgress",
      "description": "Academic progress"
    }
  }
}
